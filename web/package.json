{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:tunnel": "ngrok http --url=earmuff-sulphate-splatter.ngrok-free.dev 3000",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint && npm run verify:layout-guardrails",
    "e2e:install": "playwright install chromium",
    "e2e:setup-documents": "node --env-file=.env.local scripts/setup-e2e-documents.mjs",
    "e2e:documents": "playwright test e2e/documents-*.spec.ts",
    "e2e:documents:headed": "playwright test e2e/documents-*.spec.ts --headed",
    "e2e:documents:view": "playwright test e2e/documents-view-mode.spec.ts",
    "e2e:setup-communications": "node --env-file=.env.local scripts/setup-e2e-communications.mjs",
    "e2e:communications": "playwright test e2e/company-communications-flow.spec.ts --reporter=html",
    "e2e:communications:headed": "playwright test e2e/company-communications-flow.spec.ts --headed --reporter=html",
    "e2e:communications:view": "playwright show-report",
    "e2e:smoke": "playwright test e2e/api-smoke.spec.ts",
    "e2e:smoke:headed": "playwright test e2e/api-smoke.spec.ts --headed",
    "e2e:auth": "playwright test e2e/auth-navigation-flow.spec.ts",
    "e2e:auth:headed": "playwright test e2e/auth-navigation-flow.spec.ts --headed",
    "e2e:portal": "playwright test e2e/employee-portal-flow.spec.ts",
    "e2e:portal:headed": "playwright test e2e/employee-portal-flow.spec.ts --headed",
    "e2e:all": "playwright test",
    "test:all": "npm run test && npm run e2e:smoke && npm run e2e:auth && npm run e2e:portal",
    "setup:demo": "node --env-file=.env.local scripts/setup-demo.mjs",
    "worker:documents": "node --env-file=.env.local scripts/process-document-jobs.mjs",
    "verify:rls-isolation": "node --env-file=.env.local scripts/verify-tenant-isolation.mjs",
    "verify:operational-metrics": "node --env-file=.env.local scripts/verify-operational-metrics.mjs",
    "verify:reports-isolation": "node --env-file=.env.local scripts/verify-reports-isolation.mjs",
    "verify:role-permissions": "node --env-file=.env.local scripts/verify-role-permissions.mjs",
    "verify:module-role-e2e": "node --env-file=.env.local scripts/verify-module-role-e2e.mjs",
    "verify:smoke-modules": "node --env-file=.env.local scripts/smoke-modules.mjs",
    "setup:tenant-qa-7-locations": "node --env-file=.env.local scripts/setup-tenant-qa-7-locations.mjs",
    "verify:tenant-7-locations": "node --env-file=.env.local scripts/verify-tenant-7-locations.mjs",
    "verify:document-guardrails": "node --env-file=.env.local scripts/verify-document-guardrails.mjs",
    "verify:employee-documents-custom-flow": "node --env-file=.env.local scripts/verify-employee-documents-custom-flow.mjs",
    "verify:audit-coverage": "node --env-file=.env.local scripts/verify-audit-coverage.mjs",
    "verify:operational-metrics-consistency": "node --env-file=.env.local scripts/verify-operational-metrics-consistency.mjs",
    "verify:operational-alerts": "node --env-file=.env.local scripts/evaluate-operational-alerts.mjs",
    "apply:official-plan-packaging": "node --env-file=.env.local scripts/apply-official-plan-packaging.mjs",
    "verify:official-plan-packaging": "node --env-file=.env.local scripts/verify-official-plan-packaging.mjs",
    "verify:plan-limit-enforcement": "node --env-file=.env.local scripts/verify-plan-limit-enforcement.mjs",
    "verify:plan-limit-messages": "node --env-file=.env.local scripts/verify-plan-limit-messages.mjs",
    "verify:plan-change-rules": "node --env-file=.env.local scripts/verify-plan-change-rules.mjs",
    "verify:migrations-sync": "node scripts/verify-migrations-sync.mjs",
    "verify:docuseal": "node --env-file=.env.local scripts/verify-docuseal-integration.mjs",
    "verify:flow:local": "node --env-file=.env.local --input-type=module -e \"process.env.FLOW_ENV_LABEL='local'; process.env.KEEP_TEST_DATA='true'; if (process.env.E2E_ORG_ID && !process.env.TARGET_ORG_ID) process.env.TARGET_ORG_ID=process.env.E2E_ORG_ID; await import('./scripts/verify-announcements-documents-checklists-flow.mjs');\"",
    "verify:flow:local:cleanup": "node --env-file=.env.local --input-type=module -e \"process.env.FLOW_ENV_LABEL='local'; process.env.CLEANUP_TEST_DATA='true'; if (process.env.E2E_ORG_ID && !process.env.TARGET_ORG_ID) process.env.TARGET_ORG_ID=process.env.E2E_ORG_ID; await import('./scripts/verify-announcements-documents-checklists-flow.mjs');\"",
    "verify:flow:prod:cleanup": "node --env-file=.env.production.local --input-type=module -e \"process.env.FLOW_ENV_LABEL='production'; process.env.CLEANUP_TEST_DATA='true'; await import('./scripts/verify-announcements-documents-checklists-flow.mjs');\"",
    "verify:flow:prod:dry": "node --env-file=.env.production.local --input-type=module -e \"process.env.FLOW_ENV_LABEL='production'; process.env.KEEP_TEST_DATA='true'; await import('./scripts/verify-announcements-documents-checklists-flow.mjs');\"",
    "perf:routes": "node --env-file=.env.local scripts/measure-route-latency.mjs",
    "report:tenant-usage": "node --env-file=.env.local scripts/generate-tenant-usage-report.mjs --format=table",
    "report:tenant-usage:json": "node --env-file=.env.local scripts/generate-tenant-usage-report.mjs --format=json",
    "report:tenant-usage:csv": "node --env-file=.env.local scripts/generate-tenant-usage-report.mjs --format=csv",
    "verify:layout-guardrails": "node scripts/verify-layout-guardrails.mjs",
    "verify:qbo-r365-readiness": "node --env-file=.env.local scripts/verify-qbo-r365-readiness.mjs",
    "verify:employee-all-locations-multi-position": "node --env-file=.env.production.local scripts/verify-employee-all-locations-multi-position.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.89.0",
    "@sentry/nextjs": "^10.43.0",
    "@stripe/stripe-js": "^8.9.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "basic-ftp": "^5.3.0",
    "cron-parser": "^5.5.0",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.36.0",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.577.0",
    "next": "16.2.3",
    "pg": "^8.20.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sonner": "^2.0.7",
    "stripe": "^20.4.1",
    "twilio": "^5.13.0",
    "zod": "^4.3.6"
  },
  "overrides": {
    "axios": "^1.15.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.18.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.5",
    "docuseal": "^1.0.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "pdf-lib": "^1.17.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
