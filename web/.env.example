# =========================
# Core App
# =========================
APP_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# =========================
# Supabase (required)
# =========================
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# DB Pooler (required para scripts SQL/cron worker)
SUPABASE_DB_POOLER_HOST=aws-0-REGION.pooler.supabase.com
SUPABASE_DB_POOLER_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres.YOUR_PROJECT_REF
SUPABASE_DB_PASSWORD=YOUR_DB_PASSWORD
SUPABASE_DB_POOLER_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# Alias usado por algunos jobs
DATABASE_URL=

# =========================
# Stripe (billing)
# =========================
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# =========================
# Brevo (email)
# =========================
BREVO_API_KEY=xkeysib_xxx
BREVO_SENDER_EMAIL=dev@tu-dominio.com
BREVO_SENDER_NAME=GetBackplate
MAIL_FROM=no-reply@tu-dominio.com

# =========================
# DocuSeal (firma embebida)
# =========================
DOCUSEAL_API_URL=https://api.docuseal.com
DOCUSEAL_API_KEY=
DOCUSEAL_WEBHOOK_SECRET=

# =========================
# Twilio (SMS / WhatsApp)
# =========================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+10000000000
TWILIO_WHATSAPP_NUMBER=+14155238886
TWILIO_TRIAL_MODE=true

# =========================
# AI providers (usa Anthropic + fallback OpenRouter)
# =========================
ANTHROPIC_API_KEY=
# Modelo recomendado/forzado para IA principal
ANTHROPIC_MODEL=claude-sonnet-4-6

OPENROUTER_API_KEY=sk-or-v1-xxxx
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_MODEL_FAST=openai/gpt-4o-mini
OPENROUTER_MODEL_COMPLEX=openai/gpt-4o

# =========================
# Upstash Redis (opcional)
# =========================
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
KV_REST_API_URL=
KV_REST_API_TOKEN=

# =========================
# Seguridad / cron / workers
# =========================
CRON_SECRET=change-me
DOCUMENT_WORKER_SECRET=change-me
DOCUMENT_JOB_LIMIT=10
DOCUMENT_JOB_MAX_ATTEMPTS=5

# =========================
# Vercel Domains API (opcional, requerido para auto-verificacion de dominios custom)
# =========================
VERCEL_API_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=

# =========================
# QA / utilitarios (opcionales)
# =========================
METRICS_WINDOW_DAYS=7
DEMO_EMAIL=
TEMP_USER_PASSWORD=
PROD_SUPABASE_URL=
PROD_SUPABASE_SERVICE_ROLE_KEY=
PROD_ORG_SLUG=
PERF_COOKIE=
CI=
NEXT_RUNTIME=

# =========================
# Integraciones QBO -> R365
# =========================
# Clave de cifrado para secretos de integraciones (min 32 chars recomendado)
INTEGRATIONS_ENCRYPTION_KEY=
# Firma de state OAuth para callback seguro
QBO_OAUTH_STATE_SECRET=

# =========================
# Sentry (error tracking)
# =========================
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# =========================
# E2E / Testing (Playwright)
# =========================
E2E_EMAIL=
E2E_PASSWORD=
E2E_ORG_ID=
